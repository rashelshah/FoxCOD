{% comment %} For Shopify `json` type metafields, `.value` already returns parsed object — use directly {% endcomment %}
{% assign cod_form_submit_btn = shop.metafields.fox_cod.form_submit_button_json.value %}

{% comment %} Build product collection IDs for shipping rate collection matching {% endcomment %}
