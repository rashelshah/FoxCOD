{% if cod_quantity_offers != '[]' and cod_quantity_offers != blank %}
  <!-- [LIQUID DEBUG] Quantity offers found: {{ cod_quantity_offers | slice: 0, 200 }}... -->
{% else %}
  <!-- [LIQUID DEBUG] No quantity offers in metafield -->
{% endif %}

{% comment %} Only render COD functionality if enabled in the app {% endcomment %}
{% if cod_enabled == 'true' %}

{% comment %} Load Inter font from Google Fonts {% endcomment %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">


{% comment %} Container for COD form data - hidden, used by JavaScript {% endcomment %}
<div class="cod-form-data" 
     id="cod-data-{{ product.id }}"
     style="display: none;"
     data-product-id="{{ product.id }}"
     data-currency="{{ shop.currency }}"
     data-variant-id="{{ current_variant.id }}"
     data-product-title="{{ product.title | escape }}"
     data-product-price="{{ current_variant.price | divided_by: 100.0 }}"
     data-product-image="{% if product.featured_image %}{{ product.featured_image | image_url: width: 300 }}{% endif %}"
     data-shop="{{ shop.permanent_domain }}"
     data-app-url="{{ cod_app_url }}"
     data-max-quantity="{{ cod_max_quantity }}"
     data-button-text="{{ cod_button_text }}"
     data-primary-color="{{ cod_primary_color }}"
     data-form-theme-color="{{ form_theme_color }}"
     data-accent-color="{{ accent_color }}"
     data-form-bg="{{ form_background }}"
     data-form-type="{{ cod_form_type }}"
     data-fields="{{ cod_fields | escape }}"
     data-blocks="{{ cod_blocks | escape }}"
     data-custom-fields="{{ cod_custom_fields | escape }}"
     data-styles="{{ cod_styles_parsed | json | escape }}"
     data-button-styles="{{ cod_button_styles | escape }}"
     data-button-text-color="{{ btn_styles.textColor | default: '#ffffff' }}"
     data-button-border-color="{{ btn_styles.borderColor | default: cod_primary_color }}"
     data-button-border-width="{{ btn_styles.borderWidth | default: 0 }}"
     data-shipping-options="{{ cod_shipping_options | escape }}"
     data-shipping-rates-enabled="{{ cod_shipping_rates_enabled }}"
     data-shipping-rates="{{ cod_shipping_rates_json | escape }}"
     data-modal-style="{{ cod_modal_style }}"
     data-anim-style="{{ cod_anim_style }}"
     data-border-radius="{{ cod_border_radius }}"
     data-show-image="{{ cod_show_product_image }}"
     data-show-price="{{ cod_show_price }}"
     data-form-title="{{ cod_form_title }}"
     data-form-subtitle="{{ cod_form_subtitle }}"
     data-partial-cod-enabled="{{ cod_partial_enabled }}"
     data-partial-cod-advance="{{ cod_partial_advance }}"
     data-animation-preset="{{ btn_styles.animationPreset | default: 'none' }}"
     data-animation-speed="{{ btn_styles.animationSpeed | default: 'normal' }}"
     data-border-effect="{{ btn_styles.borderEffect | default: 'static' }}"
     data-border-intensity="{{ btn_styles.borderIntensity | default: 'medium' }}"
     data-hover-lift="{{ btn_styles.hoverLift | default: false }}"
     data-hover-glow="{{ btn_styles.hoverGlow | default: false }}"
     data-click-ripple="{{ btn_styles.clickRipple | default: false }}"
     data-click-press="{{ btn_styles.clickPress | default: false }}"
     data-sticky-mobile="{{ btn_styles.stickyOnMobile | default: false }}"
     data-quantity-offers="{{ cod_quantity_offers | escape }}"
     data-product-collection-ids="{{ product_collection_ids }}"
     data-upsell-offers="{{ cod_upsell_offers | escape }}"
     data-form-submit-button="{{ cod_form_submit_btn | json | escape }}">
</div>

{% comment %} Inject settings into global scope for reliable JavaScript access {% endcomment %}
<script>
  window.FoxCod = window.FoxCod || {};
  // Dynamic currency from shop settings
  window.FoxCod.currency = "{{ shop.currency }}";
  window.FoxCod.moneyFormat = {{ shop.money_format | json }};
  try {
    // Metafield .value outputs Ruby hash syntax (=>), use | json to convert to JS
    var offersData = {{ shop.metafields.fox_cod.quantity_offers_json.value | json }};
    window.FoxCod.quantityOffers = Array.isArray(offersData) ? offersData : (offersData ? [offersData] : []);
    window.FoxCod.productId = '{{ product.id }}';
    
    // Product variants & options for bundle variant selector
    window.FoxCod.productVariants = [
      {%- for variant in product.variants -%}
        { id: '{{ variant.id }}', title: {{ variant.title | json }}, price: {{ variant.price | divided_by: 100.0 }}, available: {{ variant.available }}, option1: {{ variant.option1 | json }}, option2: {{ variant.option2 | json | default: 'null' }}, option3: {{ variant.option3 | json | default: 'null' }} }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ];
    window.FoxCod.productOptions = [
      {%- for option in product.options -%}
        {{ option.name | json }}{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ];
    
    // Product collection IDs for collection-based shipping rate matching
    window.FoxCod.productCollectionIds = '{{ product_collection_ids }}'.split(',').filter(function(id) { return id.trim() !== ''; });
    
    // Shipping rates
    var shippingRatesData = {{ shop.metafields.fox_cod.shipping_rates_json.value | json }};
    window.FoxCod.shippingRates = Array.isArray(shippingRatesData) ? shippingRatesData : (shippingRatesData ? [shippingRatesData] : []);
    window.FoxCod.shippingRatesEnabled = {{ shop.metafields.fox_cod.shipping_rates_enabled.value | default: 'false' | json }};
    
    console.log('[FoxCod] Offers injected:', window.FoxCod.quantityOffers?.length || 0, 'groups');
    console.log('[FoxCod] Shipping rates injected:', window.FoxCod.shippingRates?.length || 0, 'rates');
    console.log('[FoxCod] Product collection IDs:', window.FoxCod.productCollectionIds);
    
    // Upsell offers
    var upsellData = {{ shop.metafields.fox_cod.upsells_downsells_json.value | json }};
    window.FoxCod.upsellOffers = upsellData || { tick_upsells: [], click_upsells: [], downsells: [] };
    console.log('[FoxCod] Upsell offers injected:', window.FoxCod.upsellOffers);
    
    // Form submit button style overrides
    var fsbRaw = {{ shop.metafields.fox_cod.form_submit_button_json.value | json | default: 'null' }};
    window.FoxCod.formSubmitButton = (fsbRaw && typeof fsbRaw === 'object') ? fsbRaw : {};
    console.log('[FoxCod] formSubmitButton injected:', window.FoxCod.formSubmitButton);
    
    // Product button styles (used as base for submit button when useProductButtonStyle is true)
    var btnStylesRaw = {{ shop.metafields.fox_cod.button_styles_json.value | json | default: 'null' }};
    window.FoxCod.buttonStyles = (btnStylesRaw && typeof btnStylesRaw === 'object') ? btnStylesRaw : {};
    console.log('[FoxCod] buttonStyles injected:', window.FoxCod.buttonStyles);
  } catch (e) {
    console.error('[FoxCod] Failed to parse settings:', e);
    window.FoxCod.quantityOffers = [];
    window.FoxCod.shippingRates = [];
    window.FoxCod.shippingRatesEnabled = false;
  }
</script>

{% comment %} Pixel Tracking — separate block so it never fails silently {% endcomment %}
<script>
  window.FoxCod = window.FoxCod || {};
  try {
    var _ptRaw = {{ shop.metafields.fox_cod.pixel_tracking_settings_json.value | json | default: 'null' }};
    window.FoxCod.pixelTracking = (typeof _ptRaw === 'object' && _ptRaw !== null) ? _ptRaw : {};
  } catch (e) {
    window.FoxCod.pixelTracking = {};
  }
  console.log('[FoxCod] Pixel tracking loaded:', window.FoxCod.pixelTracking);
</script>

{% comment %} Fraud Protection — inject settings for client-side validation {% endcomment %}
<script>
  window.FoxCod = window.FoxCod || {};
  try {
    var _fpRaw = {{ shop.metafields.fox_cod.fraud_protection_settings_json.value | json | default: 'null' }};
    window.FoxCod.fraudProtection = (typeof _fpRaw === 'object' && _fpRaw !== null) ? _fpRaw : {};
  } catch (e) {
    window.FoxCod.fraudProtection = {};
  }
  console.log('[FoxCod] Fraud protection loaded:', window.FoxCod.fraudProtection);
</script>

{% comment %} Modal Overlay {% endcomment %}
<div class="cod-modal-overlay" id="cod-modal-overlay-{{ product.id }}" style="display: none;">

<div class="cod-form-container cod-modal" 
     id="cod-form-{{ product.id }}"
     style="display: none;">
  
  {% comment %} Close Button {% endcomment %}
  <button type="button" class="cod-close-btn" data-cod-close="{{ product.id }}">&times;</button>

  {% comment %} Product Info {% endcomment %}
  {% if cod_show_product_image == 'true' or cod_show_price == 'true' %}
  <div class="cod-product-info">
    {% if cod_show_product_image == 'true' and product.featured_image %}
      <div class="cod-product-image-wrapper" style="position:relative; display:inline-block;">
        <span class="cod-qty-badge" style="position:absolute; top:-6px; right:-6px; background:#000000; color:#fff; font-size:11px; font-weight:700; width:20px; height:20px; border-radius:50%; display:flex; align-items:center; justify-content:center; z-index:2; line-height:1;">1</span>
        <img src="{{ product.featured_image | image_url: width: 100 }}" 
             alt="{{ product.title }}" 
             class="cod-product-image"
             width="80"
             height="80"
             loading="lazy">
      </div>
    {% endif %}
    <div class="cod-product-details">
      <h3 class="cod-product-title">{{ product.title }}</h3>
      {% if cod_show_price == 'true' %}
          <p class="cod-product-price" style="color: {{ accent_color }};">{{ product_price_display }}</p>
      {% endif %}
      {% if current_variant.title != 'Default Title' %}
        <p class="cod-variant-title">{{ current_variant.title }}</p>
      {% endif %}
    </div>
    {%- comment -%} Quantity Selector — hidden when bundle offers are active {%- endcomment -%}
    <div class="cod-product-qty" data-max-qty="{{ cod_max_quantity }}">
      <button type="button" class="cod-qty-btn cod-qty-minus" aria-label="Decrease quantity">−</button>
      <input type="number" name="quantity" class="cod-qty-input" value="1" min="1" max="{{ cod_max_quantity }}" readonly>
      <button type="button" class="cod-qty-btn cod-qty-plus" aria-label="Increase quantity">+</button>
    </div>
  </div>
  {% endif %}
  
  <div class="cod-form-headers" style="text-align: center; margin-bottom: 16px;">
      {% if cod_form_title != blank %}<h2 style="margin: 0; font-size: 20px;">{{ cod_form_title }}</h2>{% endif %}
      {% if cod_form_subtitle != blank %}<p style="margin: 4px 0 0; color: #666; font-size: 14px;">{{ cod_form_subtitle }}</p>{% endif %}
  </div>

  {% comment %} COD Form - Dynamic Content Rendered by JS {% endcomment %}
  <form id="cod-order-form-{{ product.id }}" class="cod-order-form" novalidate>
      <div class="cod-dynamic-fields-container">
          <!-- Fields will be injected here by cod-form.js -->
      </div>

    {% comment %} Total Price {% endcomment %}
    <div class="cod-total">
      <span>Total:</span>
      <span class="cod-total-price" data-unit-price="{{ current_variant.price | divided_by: 100.0 }}" style="color: {{ accent_color }};">
        {{ product_price }}
      </span>
    </div>

    {% comment %} Submit Button — styles applied via JS from window.FoxCod.formSubmitButton / button_styles {% endcomment %}
    <button type="submit"
            class="cod-submit-btn"
            data-primary-color="{{ cod_primary_color }}"
            style="width:100%; padding:13px; border-radius:12px; border:none; cursor:pointer; font-size:15px; font-weight:700; color:#fff; background-color:{{ cod_primary_color }}; transition:all 0.2s ease;">
      {{ shop.metafields.fox_cod.submit_button_text | default: 'Place Order (COD)' }}
    </button>

    {% comment %} Status Messages {% endcomment %}
    <div class="cod-message cod-message-success" style="display: none;">
      <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
      <span class="cod-message-text">Order placed successfully!</span>
    </div>
    <div class="cod-message cod-message-error" style="display: none;">
      <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
      <span class="cod-message-text">Something went wrong</span>
    </div>
  </form>
</div>

</div>

<style>
  /* COD Buy Button - styled to match theme buttons */
  .cod-buy-btn {
    width: 100%;
    padding: 14px 20px;
    border: none;
    border-radius: 6px;
    color: #fff;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease;
    text-align: center;
    display: block;
    box-sizing: border-box;
  }

  /* Only apply hover transform when NO animation class is present */
  .cod-buy-btn:not(.btn-anim-shake):not(.btn-anim-pulse):not(.btn-anim-bounce):not(.btn-anim-glow):not(.btn-anim-gradient-flow):not(.btn-anim-shimmer):hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
  .cod-buy-btn.btn-anim-shake:hover,
  .cod-buy-btn.btn-anim-pulse:hover,
  .cod-buy-btn.btn-anim-bounce:hover,
  .cod-buy-btn.btn-anim-glow:hover {
    opacity: 0.9;
  }

  /* Modal Overlay - prevent horizontal swipe/scroll */
  .cod-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 99998;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    animation: fadeIn 0.2s ease;
    touch-action: pan-y;
    overflow-x: hidden;
    overscroll-behavior-x: contain;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* Modal Container - prevent horizontal swipe */
  .cod-form-container.cod-modal {
    position: relative;
    z-index: 99999;
    touch-action: pan-y;
    overscroll-behavior-x: none;
    animation: slideUp 0.3s ease;
  }

  /* Desktop: constrain height so form scrolls inside and rounded corners stay visible */
  @media only screen and (min-width: 601px) {
    .cod-form-container.cod-modal {
      max-height: 85vh;
      overflow-y: auto;
    }
  }

  @keyframes slideUp {
    from { 
      opacity: 0;
      transform: translateY(20px);
    }
    to { 
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Close Button */
  .cod-close-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 32px;
    height: 32px;
    border: none;
    background: #f5f5f5;
    border-radius: 50%;
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    color: #666;
    transition: all 0.2s;
  }

  .cod-close-btn:hover {
    background: #e0e0e0;
    color: #333;
  }

  /* Base Container */
  .cod-form-container {
    max-width: 500px;
    padding: 20px;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    background: #fff;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .cod-product-info {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid #e5e5e5;
  }

  .cod-product-image {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 12px;
  }

  .cod-product-details {
    flex: 1;
    min-width: 0;
  }

  .cod-product-qty {
    display: flex !important;
    align-items: center !important;
    flex-shrink: 0;
    border: 1px solid #d1d5db !important;
    border-radius: 999px !important;
    overflow: hidden !important;
    background: #fff !important;
    gap: 0 !important;
  }
  .cod-product-qty .cod-qty-btn {
    width: 38px !important;
    height: 36px !important;
    border: none !important;
    border-radius: 0 !important;
    background: #f3f4f6 !important;
    font-size: 18px !important;
    font-weight: 500;
    cursor: pointer;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    color: #6b7280;
    transition: all 0.15s;
    padding: 0 !important;
    line-height: 1;
    margin: 0 !important;
    min-width: unset !important;
    box-shadow: none !important;
    outline: none !important;
    -webkit-appearance: none !important;
    appearance: none !important;
