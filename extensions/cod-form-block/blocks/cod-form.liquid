{% elsif theme_key == 'dark_mode' %}{% assign form_theme_color = '#6366f1' %}
{% elsif theme_key == 'eastern_gold' %}{% assign form_theme_color = '#b45309' %}
{% elsif theme_key == 'arctic_blue' %}{% assign form_theme_color = '#0891b2' %}
{% elsif theme_key == 'rose_garden' %}{% assign form_theme_color = '#e11d48' %}
{% elsif theme_key == 'midnight_purple' %}{% assign form_theme_color = '#7c3aed' %}
{% elsif theme_key == 'forest_green' %}{% assign form_theme_color = '#16a34a' %}
{% elsif theme_key == 'professional' %}{% assign form_theme_color = '#374151' %}
{% elsif theme_key == 'minimal_white' %}{% assign form_theme_color = '#111827' %}
{% elsif theme_key == 'luxury_gold' %}{% assign form_theme_color = '#d97706' %}
{% elsif theme_key == 'ocean_breeze' %}{% assign form_theme_color = '#14b8a6' %}
{% elsif theme_key == 'default' %}{% assign form_theme_color = '#000000' %}
